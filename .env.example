# Copy this file to .env and fill in your own local values.
# NEVER commit your real .env file to version control.

# SQLite database path (relative to project root)
DATABASE_URL=sqlite:///./visitor_parking.db

# Directory where debug screenshots are stored
SCREENSHOT_DIR=./screenshots
SCREENSHOT_RETENTION_HOURS=24

# Register2Park defaults
REGISTER2PARK_URL=https://www.register2park.com/
REGISTER2PARK_PROPERTY_NAME=Lakeside Urban Center Apartments

# Playwright browser behavior
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT_MS=30000
MANUAL_CAPTCHA_TIMEOUT_SECONDS=300

# Scheduler interval, in seconds, for the local MVP loop (7200 = 2 hours)
SCHEDULER_INTERVAL_SECONDS=7200
SCREENSHOT_CLEANUP_INTERVAL_SECONDS=3600

# Retry delay (minutes) after a failed registration attempt
RETRY_DELAY_MINUTES=30

# Logging
LOG_LEVEL=INFO

# --- Personal / vehicle data ---
# Do NOT put real personal data here in a committed file.
# These are only examples for local .env use; the API request body
# is the primary way to submit real registration data.
DEFAULT_EMAIL=
DEFAULT_PLATE_NUMBER=
DEFAULT_PLATE_STATE=
